# ─────────────────────────────────────────────
# Bandung Apparel AI Customer Service — .env
# ─────────────────────────────────────────────

# API Key Anthropic Claude
# Dapatkan di: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_api_key_here

# Port server (default: 3000)
PORT=3000

# Token Telegram Bot
# Dapatkan dengan membuat bot baru via @BotFather di Telegram
TELEGRAM_BOT_TOKEN=your_token_here

# ID Google Spreadsheet
# Ambil dari URL sheet: https://docs.google.com/spreadsheets/d/<SHEET_ID>/edit
# Pastikan service account (credentials.json) sudah diberi akses "Viewer" ke spreadsheet ini
GOOGLE_SHEET_ID=your_spreadsheet_id_here
